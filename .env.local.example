# Copy this to .env.local and fill in your values

# ── Newsletter (Resend) ──────────────────────────────────────────────────────
# Get a free API key at https://resend.com (3,000 emails/month free)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Email address that receives new subscriber notifications
NOTIFY_EMAIL=you@apollotechnologies.us

# ── PicoClaw: Quick AI Post Generator ───────────────────────────────────────
# Choose your provider: "google" or "groq"
PICOCLAW_PROVIDER=google

# Google Gemini API key — https://aistudio.google.com/apikey (free tier available)
GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq API key — https://console.groq.com (very fast, generous free tier)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenClaw: Research Post Generator (Local Ollama) ────────────────────────
# Ollama must be running locally: https://ollama.com
# Pull a model first: ollama pull llama3.2  OR  ollama pull mistral
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
